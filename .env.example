# PixelForge Environment Variables
# Copy to .env and adjust for your deployment

# JWT secret for auth tokens (must be ≥32 chars — CHANGE THIS in production!)
JWT_SECRET=pixelforge-super-secret-change-me-32b!

# Set to 1 only for local tests without a GPU; 0 = load models (requires NVIDIA GPU)
PIXELFORGE_SKIP_LOAD=0

# Frontend API URL (used during Vite build)
VITE_API_URL=/api
